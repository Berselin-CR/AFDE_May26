{
  "info": {
    "name": "Feedback Management System",
    "description": "Complete API collection for the Feedback Management System.\n\n**Base URL:** http://127.0.0.1:8000/api\n\n**Auth:** PUT and DELETE endpoints require the header `X-Role: admin`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "feedback_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Check if the API is running."
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "Get All Feedback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/feedback/",
              "host": ["{{base_url}}"],
              "path": ["feedback", ""]
            },
            "description": "Retrieve all feedback entries ordered by most recent."
          }
        },
        {
          "name": "Get Feedback by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/feedback/{{feedback_id}}",
              "host": ["{{base_url}}"],
              "path": ["feedback", "{{feedback_id}}"]
            },
            "description": "Retrieve a single feedback entry by its ID."
          }
        },
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participant_name\": \"John Doe\",\n  \"program_name\": \"Leadership Workshop\",\n  \"rating\": 5,\n  \"comments\": \"Excellent session, very insightful!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/feedback/",
              "host": ["{{base_url}}"],
              "path": ["feedback", ""]
            },
            "description": "Submit a new feedback entry. Rating must be between 1 and 5. Comments are optional."
          }
        },
        {
          "name": "Submit Feedback (Minimum Fields)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participant_name\": \"Jane Smith\",\n  \"program_name\": \"Onboarding Program\",\n  \"rating\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/feedback/",
              "host": ["{{base_url}}"],
              "path": ["feedback", ""]
            },
            "description": "Submit feedback without optional comments field."
          }
        },
        {
          "name": "Update Feedback (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Role",
                "value": "admin",
                "description": "Required for PUT. Remove or change to non-admin to test 403."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participant_name\": \"John Doe\",\n  \"program_name\": \"Leadership Workshop\",\n  \"rating\": 4,\n  \"comments\": \"Updated: Good session overall.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/feedback/{{feedback_id}}",
              "host": ["{{base_url}}"],
              "path": ["feedback", "{{feedback_id}}"]
            },
            "description": "Update an existing feedback entry. Requires `X-Role: admin` header. All fields are optional (partial update supported)."
          }
        },
        {
          "name": "Update Feedback - Partial (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Role",
                "value": "admin"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comments\": \"Revised after reflection — truly excellent!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/feedback/{{feedback_id}}",
              "host": ["{{base_url}}"],
              "path": ["feedback", "{{feedback_id}}"]
            },
            "description": "Partially update only specific fields of a feedback entry."
          }
        },
        {
          "name": "Delete Feedback (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Role",
                "value": "admin",
                "description": "Required for DELETE. Remove or change to test 403."
              }
            ],
            "url": {
              "raw": "{{base_url}}/feedback/{{feedback_id}}",
              "host": ["{{base_url}}"],
              "path": ["feedback", "{{feedback_id}}"]
            },
            "description": "Delete a feedback entry by ID. Requires `X-Role: admin` header. Returns 204 No Content on success."
          }
        }
      ]
    },
    {
      "name": "Search & Filter",
      "item": [
        {
          "name": "Search - All Results",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search",
              "host": ["{{base_url}}"],
              "path": ["search"]
            },
            "description": "Returns all feedback when no filters are applied."
          }
        },
        {
          "name": "Search - By Keyword",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?keyword=leadership",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                {
                  "key": "keyword",
                  "value": "leadership",
                  "description": "Searches across participant_name, program_name, and comments (case-insensitive)"
                }
              ]
            },
            "description": "Search feedback by keyword across participant name, program name, and comments."
          }
        },
        {
          "name": "Search - By Rating",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?rating=5",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                {
                  "key": "rating",
                  "value": "5",
                  "description": "Exact rating filter (1–5)"
                }
              ]
            },
            "description": "Filter feedback by exact rating value (1 to 5)."
          }
        },
        {
          "name": "Search - By Program Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?program_name=workshop",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                {
                  "key": "program_name",
                  "value": "workshop",
                  "description": "Case-insensitive partial match on program_name"
                }
              ]
            },
            "description": "Filter feedback by program/event name (partial, case-insensitive match)."
          }
        },
        {
          "name": "Search - Combined Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/search?keyword=john&rating=5&program_name=workshop",
              "host": ["{{base_url}}"],
              "path": ["search"],
              "query": [
                {
                  "key": "keyword",
                  "value": "john"
                },
                {
                  "key": "rating",
                  "value": "5"
                },
                {
                  "key": "program_name",
                  "value": "workshop"
                }
              ]
            },
            "description": "Use all three filters together. All are optional and combinable."
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Get Non-Existent Feedback (404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/feedback/99999",
              "host": ["{{base_url}}"],
              "path": ["feedback", "99999"]
            },
            "description": "Returns 404 when feedback ID does not exist."
          }
        },
        {
          "name": "Delete Without Admin Header (403)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Role",
                "value": "user",
                "description": "Non-admin role — should return 403 Forbidden"
              }
            ],
            "url": {
              "raw": "{{base_url}}/feedback/{{feedback_id}}",
              "host": ["{{base_url}}"],
              "path": ["feedback", "{{feedback_id}}"]
            },
            "description": "Tests that non-admin users cannot delete feedback. Expects 403 Forbidden."
          }
        },
        {
          "name": "Submit Invalid Rating (422)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participant_name\": \"Test User\",\n  \"program_name\": \"Test Program\",\n  \"rating\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/feedback/",
              "host": ["{{base_url}}"],
              "path": ["feedback", ""]
            },
            "description": "Tests Pydantic validation. Rating must be 1–5. Expects 422 Unprocessable Entity."
          }
        }
      ]
    }
  ]
}
